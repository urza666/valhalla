# ═══════════════════════════════════════════════════════════
# Valhalla Web Client — Nginx Static Build
# ═══════════════════════════════════════════════════════════

# ── Stage 1: Node Build ───────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY web/package.json web/package-lock.json* ./
RUN npm ci 2>/dev/null || npm install

COPY web/ .
RUN npm run build

# ── Stage 2: Nginx Static Serving ─────────────────────────
FROM nginx:1.27-alpine

# Remove default config
RUN rm /etc/nginx/conf.d/default.conf

COPY deployments/nginx/valhalla.conf /etc/nginx/conf.d/valhalla.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80 443

HEALTHCHECK --interval=15s --timeout=3s --retries=3 \
    CMD wget -q --spider --no-check-certificate https://localhost/health || exit 1
