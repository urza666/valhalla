# Valhalla Self-Hosted Configuration
# Copy to .env and set all required values

# Domain (used by Caddy for auto-TLS)
DOMAIN=valhalla.example.com

# API
API_PORT=8080
API_HOST=0.0.0.0

# Database (REQUIRED)
DB_USER=valhalla
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=valhalla
DATABASE_URL=postgres://valhalla:CHANGE_ME_STRONG_PASSWORD@postgres:5432/valhalla?sslmode=disable

# Redis (REQUIRED)
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# NATS
NATS_URL=nats://nats:4222

# Auth (REQUIRED - generate with: openssl rand -hex 32)
TOKEN_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# LiveKit (REQUIRED - generate with: openssl rand -hex 16)
LIVEKIT_HOST=http://livekit:7880
LIVEKIT_API_KEY=CHANGE_ME_LIVEKIT_KEY
LIVEKIT_API_SECRET=CHANGE_ME_LIVEKIT_SECRET

# MinIO / S3 (REQUIRED)
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
STORAGE_SECRET_KEY=CHANGE_ME_MINIO_SECRET
STORAGE_BUCKET=valhalla-assets
STORAGE_USE_SSL=false

# Meilisearch (REQUIRED)
MEILI_URL=http://meilisearch:7700
MEILI_API_KEY=CHANGE_ME_MEILI_KEY

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Snowflake
SNOWFLAKE_WORKER_ID=0
SNOWFLAKE_PROCESS_ID=0
