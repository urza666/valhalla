# Valhalla Configuration
# Copy to .env and adjust values

# Server
API_PORT=8080
GATEWAY_PORT=8081
API_HOST=0.0.0.0

# Database
DATABASE_URL=postgres://valhalla:valhalla@localhost:5432/valhalla?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# NATS
NATS_URL=nats://localhost:4222

# Auth
TOKEN_SECRET=change-me-to-a-random-64-char-string
TOKEN_TTL=168h

# Snowflake
SNOWFLAKE_WORKER_ID=0
SNOWFLAKE_PROCESS_ID=0

# Storage (S3-compatible)
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=valhalla-assets
STORAGE_USE_SSL=false

# Meilisearch
MEILI_URL=http://localhost:7700
MEILI_API_KEY=change-me

# LiveKit (Voice/Video)
LIVEKIT_HOST=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Log
LOG_LEVEL=debug
LOG_FORMAT=console
