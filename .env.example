# ═══════════════════════════════════════════════════════════
# Valhalla Configuration
# ═══════════════════════════════════════════════════════════
# Copy to .env:  cp .env.example .env
# Then run:      docker compose up -d
# ═══════════════════════════════════════════════════════════

# ─── Ports ────────────────────────────────────────────────
WEB_PORT=80
API_PORT=8080
MINIO_CONSOLE_PORT=9001

# ─── Database (PostgreSQL) ────────────────────────────────
DB_USER=valhalla
DB_PASSWORD=valhalla
DB_NAME=valhalla
# DATABASE_URL is auto-constructed in docker-compose.yml

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=valhalla
# REDIS_URL is auto-constructed in docker-compose.yml

# ─── Auth ─────────────────────────────────────────────────
# IMPORTANT: Change this to a random string in production!
# Generate with: openssl rand -hex 32
TOKEN_SECRET=change-me-to-a-random-64-char-string-in-production
TOKEN_TTL=168h

# ─── Snowflake ID Generator ──────────────────────────────
SNOWFLAKE_WORKER_ID=0
SNOWFLAKE_PROCESS_ID=0

# ─── Object Storage (MinIO / S3) ─────────────────────────
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=valhalla-assets
STORAGE_USE_SSL=false

# ─── Search (Meilisearch) ────────────────────────────────
MEILI_API_KEY=valhalla-dev-key
MEILI_ENV=development

# ─── Voice/Video (LiveKit) ───────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=console

# ─── Server (internal, usually no need to change) ────────
API_HOST=0.0.0.0
GATEWAY_PORT=8081
